#!/bin/bash
# session-noticer-hook: Called by Claude Code hooks to write event files
# Usage: session-noticer-hook <event_type>
# Reads hook JSON payload from stdin

set -euo pipefail

EVENT_TYPE="${1:-unknown}"
EVENTS_DIR="$HOME/Library/Application Support/SessionNoticer/events"
mkdir -p "$EVENTS_DIR"

# Read full payload from stdin
PAYLOAD=$(cat)

# Debug: log raw payload to help diagnose hook issues
DEBUG_DIR="$HOME/Library/Application Support/SessionNoticer/debug"
mkdir -p "$DEBUG_DIR"
echo "$(date '+%Y-%m-%d %H:%M:%S') [$EVENT_TYPE] $PAYLOAD" >> "$DEBUG_DIR/hook-payloads.log"

# $PPID is the Claude Code process PID (bash's parent).
# os.getppid() in Python would give bash's PID (ephemeral, dies after hook).
CLAUDE_PID=${PPID}

# Extract all fields and write event file atomically in a single python3 call
printf '%s' "$PAYLOAD" | /usr/bin/python3 -c "
import sys, json, time, os, tempfile

d = json.load(sys.stdin)
ts = int(time.time() * 1000)
event_type = '${EVENT_TYPE}'
claude_pid = ${CLAUDE_PID}

event = {
    'event': event_type,
    'session_id': d.get('session_id', 'unknown'),
    'pid': claude_pid,
    'cwd': d.get('cwd', ''),
    'transcript_path': d.get('transcript_path', ''),
    'notification_type': d.get('notification_type', ''),
    'timestamp': ts
}

events_dir = os.path.expanduser('~/Library/Application Support/SessionNoticer/events')
filename = f'{ts}-{event_type}-{os.getpid()}.json'
filepath = os.path.join(events_dir, filename)

# Atomic write: write to temp file, then rename
fd, tmp_path = tempfile.mkstemp(dir=events_dir, suffix='.tmp')
try:
    with os.fdopen(fd, 'w') as f:
        json.dump(event, f)
    os.rename(tmp_path, filepath)
except:
    try: os.unlink(tmp_path)
    except: pass
    raise
"
